<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Match the source project TFM for Stride 4.3 -->
    <TargetFramework Condition="$([MSBuild]::IsOSPlatform('Windows'))">net10.0-windows</TargetFramework>
    <TargetFramework Condition="!$([MSBuild]::IsOSPlatform('Windows'))">net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <OutputType>Exe</OutputType>
    <IsTestProject>true</IsTestProject>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>BeyondImmersion.Bannou.VoxelBuilder.Stride.Tests</RootNamespace>
    <AssemblyName>BeyondImmersion.Bannou.VoxelBuilder.Stride.Tests</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../voxel-builder-stride/BeyondImmersion.Bannou.VoxelBuilder.Stride.csproj" />
  </ItemGroup>

</Project>
