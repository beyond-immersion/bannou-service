<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Use net10.0 to match the SDK (without -windows since tests don't use Stride directly) -->
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <RootNamespace>BeyondImmersion.Bannou.SceneComposer.Stride.Tests</RootNamespace>

    <IsPackable>false</IsPackable>
    <Configurations>Debug;Release;Development</Configurations>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../scene-composer-stride/Bannou.Stride.SceneComposer.csproj" />
  </ItemGroup>

  <!-- Test fixture files -->
  <ItemGroup>
    <Content Include="TestFixtures/**/*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
