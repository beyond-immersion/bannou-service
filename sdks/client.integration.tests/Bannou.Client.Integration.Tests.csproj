<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <RootNamespace>BeyondImmersion.Bannou.Client.Integration.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reference Client SDK for client-side runtime classes -->
    <ProjectReference Include="../client/Bannou.Client.csproj" />

    <!-- Reference lib-behavior for BehaviorCompiler (round-trip testing) -->
    <ProjectReference Include="../../plugins/lib-behavior/lib-behavior.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Copy YAML test fixtures to output directory -->
    <None Include="Behavior\fixtures\**\*.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
