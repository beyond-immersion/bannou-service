<Project Sdk="Godot.NET.Sdk/4.3.0">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12.0</LangVersion>
    <OutputType>Exe</OutputType>
    <RootNamespace>BeyondImmersion.Bannou.SceneComposer.Godot.Tests</RootNamespace>
    <AssemblyName>BeyondImmersion.Bannou.SceneComposer.Godot.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Disable Godot-specific build targets that require the editor -->
    <EnableGodotAnalyzers>false</EnableGodotAnalyzers>
    <!-- Override Godot SDK's non-standard output path for test runner compatibility -->
    <OutputPath>bin/$(Configuration)/$(TargetFramework)</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reference Godot SceneComposer SDK -->
    <ProjectReference Include="../scene-composer-godot/Bannou.Godot.SceneComposer.csproj" />
    <!-- Reference base SceneComposer SDK for SDK types -->
    <ProjectReference Include="../scene-composer/Bannou.SceneComposer.csproj" />
  </ItemGroup>

</Project>
